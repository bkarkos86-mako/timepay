# SQLite for local/free dev. Swap to a Postgres URL (Neon/Supabase free tier) for production:
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=4000

# WebAuthn (passkey/biometric login). rpID must be the bare domain the app is
# served from (no scheme/port) and must match the browser's actual origin, or
# passkey registration/login will fail. "localhost" covers any localhost port
# in dev. Update all three once this is deployed behind a real HTTPS domain.
WEBAUTHN_RP_NAME="TimePay"
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_ORIGIN="http://localhost:5183"

# Web Push (browser notifications — free, no third-party service; delivered
# straight to each browser's own push endpoint). Generated once with
# `node -e "console.log(require('web-push').generateVAPIDKeys())"` — keep the
# private key secret, the public key is safe to expose to the frontend.
VAPID_PUBLIC_KEY="BNwrty53MGIopis5oRW1xar1ctjSqevxPtDkLJdqVZ4oaKLvhF5BXs22epYDNJI8d3DZiTG8IbRJmHIVc0ES41M"
VAPID_PRIVATE_KEY="2-8JHGrQsxXVbB91trNOoIQpv-QWkUUn8_f0ktYGfKc"
VAPID_SUBJECT="mailto:admin@example.com"
